the dependency array.","ArrayExpression",["214"],["215"],"The 'fetchData' function makes the dependencies of useEffect Hook (at line 94) change on every render. To fix this, wrap the definition of 'fetchData' in its own useCallback() Hook.","VariableDeclarator",["216"],"React Hook useEffect has a missing dependency: 'navigate'. Either include it or remove the dependency array.",["217"],"'cardBg' is assigned a value but never used.",{"desc":"218","fix":"219"},{"kind":"220","justification":"221"},{"desc":"222","fix":"223"},{"desc":"224","fix":"225"},"Update the dependencies array to be: [fetchCompanyProfile]",{"range":"226","text":"227"},"directive","","Wrap the definition of 'fetchData' in its own useCallback() Hook.",{"range":"228","text":"229"},"Update the dependencies array to be: [navigate]",{"range":"230","text":"231"},[1711,1713],"[fetchCompanyProfile]",[2906,3836],"useCallback(async () => {\n        if (activeTab === 'stats') return;\n        setLoading(true);\n        try {\n            if (activeTab === 'users') {\n                const res = await api.get('/admin/users');\n                setUsers(res.data);\n            } else if (activeTab === 'jobs') {\n                const res = await api.get('/admin/jobs');\n                setJobs(res.data);\n            } else if (activeTab === 'applications') {\n                const res = await api.get('/admin/applications');\n                setApplications(res.data);\n            } else if (activeTab === 'testimonials') {\n                const res = await api.get('/admin/testimonials');\n                setTestimonials(res.data);\n            }\n        } catch (err) {\n            console.error('Error fetching data:', err);\n            showNotification('Gagal', 'Gagal memuat data', 'error');\n        } finally {\n            setLoading(false);\n        }\n    })",[1098,1100],"[navigate]"]