"378","messageId":"379","endLine":88,"endColumn":15},"no-unused-vars","'AdminStatsView' is defined but never used.","Identifier","unusedVar","'isDark' is assigned a value but never used.","no-dupe-keys","Duplicate key 'border'.","ObjectExpression","unexpected","react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'fetchCompanyProfile'. Either include it or remove the dependency array.","ArrayExpression",["395"],["396"],"The 'fetchData' function makes the dependencies of useEffect Hook (at line 94) change on every render. To fix this, wrap the definition of 'fetchData' in its own useCallback() Hook.","VariableDeclarator",["397"],"React Hook useEffect has a missing dependency: 'navigate'. Either include it or remove the dependency array.",["398"],"'cardBg' is assigned a value but never used.",["399"],["400"],["401"],["402"],{"desc":"403","fix":"404"},{"kind":"405","justification":"406"},{"desc":"407","fix":"408"},{"desc":"409","fix":"410"},{"desc":"409","fix":"411"},{"desc":"403","fix":"412"},{"kind":"405","justification":"406"},{"desc":"407","fix":"413"},"Update the dependencies array to be: [fetchCompanyProfile]",{"range":"414","text":"415"},"directive","","Wrap the definition of 'fetchData' in its own useCallback() Hook.",{"range":"416","text":"417"},"Update the dependencies array to be: [navigate]",{"range":"418","text":"419"},{"range":"420","text":"419"},{"range":"421","text":"415"},{"range":"422","text":"417"},[1711,1713],"[fetchCompanyProfile]",[2906,3836],"useCallback(async () => {\n        if (activeTab === 'stats') return;\n        setLoading(true);\n        try {\n            if (activeTab === 'users') {\n                const res = await api.get('/admin/users');\n                setUsers(res.data);\n            } else if (activeTab === 'jobs') {\n                const res = await api.get('/admin/jobs');\n                setJobs(res.data);\n            } else if (activeTab === 'applications') {\n                const res = await api.get('/admin/applications');\n                setApplications(res.data);\n            } else if (activeTab === 'testimonials') {\n                const res = await api.get('/admin/testimonials');\n                setTestimonials(res.data);\n            }\n        } catch (err) {\n            console.error('Error fetching data:', err);\n            showNotification('Gagal', 'Gagal memuat data', 'error');\n        } finally {\n            setLoading(false);\n        }\n    })",[1098,1100],"[navigate]",[1098,1100],[1711,1713],[2906,3836]]