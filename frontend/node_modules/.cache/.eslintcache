19"},{"desc":"418","fix":"420"},{"desc":"412","fix":"421"},{"kind":"414","justification":"415"},{"desc":"416","fix":"422"},"Update the dependencies array to be: [fetchCompanyProfile]",{"range":"423","text":"424"},"directive","","Wrap the definition of 'fetchData' in its own useCallback() Hook.",{"range":"425","text":"426"},"Update the dependencies array to be: [navigate]",{"range":"427","text":"428"},{"range":"429","text":"428"},{"range":"430","text":"424"},{"range":"431","text":"426"},[1711,1713],"[fetchCompanyProfile]",[2906,3836],"useCallback(async () => {\n        if (activeTab === 'stats') return;\n        setLoading(true);\n        try {\n            if (activeTab === 'users') {\n                const res = await api.get('/admin/users');\n                setUsers(res.data);\n            } else if (activeTab === 'jobs') {\n                const res = await api.get('/admin/jobs');\n                setJobs(res.data);\n            } else if (activeTab === 'applications') {\n                const res = await api.get('/admin/applications');\n                setApplications(res.data);\n            } else if (activeTab === 'testimonials') {\n                const res = await api.get('/admin/testimonials');\n                setTestimonials(res.data);\n            }\n        } catch (err) {\n            console.error('Error fetching data:', err);\n            showNotification('Gagal', 'Gagal memuat data', 'error');\n        } finally {\n            setLoading(false);\n        }\n    })",[1098,1100],"[navigate]",[1258,1260],[1956,1958],[3366,4296]]